      const containerRect = scrollContainer.getBoundingClientRect();
      const viewportHeight = containerRect.height;
      const scrollZoneSize = viewportHeight * 0.5; // 50% of viewport height for scroll zones
      
      // Clear existing interval
      if (scrollInterval) {
        clearInterval(scrollInterval);
        scrollInterval = null;
      }
      
      // Calculate relative position in the container
      const relativeY = e.clientY - containerRect.top;
      
      // Determine scroll speed based on distance from edge
      let scrollSpeed = 0;
      if (relativeY < scrollZoneSize && relativeY > 0) {
        // In top scroll zone - speed increases closer to edge
        const distanceRatio = 1 - (relativeY / scrollZoneSize);
        scrollSpeed = -Math.max(5, Math.min(20, distanceRatio * 20));
      } else if (relativeY > viewportHeight - scrollZoneSize && relativeY < viewportHeight) {
        // In bottom scroll zone - speed increases closer to edge
        const distanceRatio = (relativeY - (viewportHeight - scrollZoneSize)) / scrollZoneSize;
        scrollSpeed = Math.max(5, Math.min(20, distanceRatio * 20));
      }
      
      // Start scrolling if speed is set
      if (scrollSpeed !== 0) {
        scrollInterval = setInterval(() => {
          scrollContainer.scrollTop += scrollSpeed;
        }, 20);
      }
    };
    
    container.ondragover = (e) => {
      e.preventDefault();
      e.stopPropagation();
      // Only show drop zone if it's from internal drag, not file drag
      if (window.draggedElement && window.draggedElement !== container && !e.dataTransfer?.types.includes('Files')) {
        const rect = container.getBoundingClientRect();
        const relativeY = e.clientY - rect.top;
        const dropZoneHeight = Math.min(rect.height * 0.5, 80); // 50% of height or 80px max
        
        // Clear previous styles
        container.style.borderTop = 'none';
        container.style.borderBottom = 'none';
        container.style.paddingTop = '0';
        container.style.paddingBottom = '0';
        container.style.marginTop = '1rem';
        container.style.marginBottom = '1rem';
        
        // Create drop indicator
        let dropIndicator = document.getElementById('drop-indicator');
        if (!dropIndicator) {
          dropIndicator = document.createElement('div');
          dropIndicator.id = 'drop-indicator';
          dropIndicator.style.cssText = `
            position: absolute;
            left: 0;
            right: 0;
            height: 6px;
            background: #3b82f6;
            box-shadow: 0 0 12px rgba(59, 130, 246, 0.8), 0 0 4px rgba(59, 130, 246, 0.4);
            pointer-events: none;
            z-index: 1000;
            transition: all 0.2s ease;
            border-radius: 3px;
          `;
          previewContentRef?.appendChild(dropIndicator);
        }
        
        // Position the indicator
        if (relativeY < dropZoneHeight) {
          // Top drop zone
          dropIndicator.style.top = `${rect.top - container.parentElement!.getBoundingClientRect().top - 2}px`;
          dropIndicator.style.display = 'block';
          container.style.paddingTop = '20px';
          container.style.marginTop = '0.5rem';
        } else if (relativeY > rect.height - dropZoneHeight) {
          // Bottom drop zone
          dropIndicator.style.top = `${rect.bottom - container.parentElement!.getBoundingClientRect().top - 2}px`;
          dropIndicator.style.display = 'block';
          container.style.paddingBottom = '20px';
          container.style.marginBottom = '0.5rem';
        } else {
          dropIndicator.style.display = 'none';
        }
      }
    };
    
    container.ondragleave = () => {
      container.style.borderTop = 'none';
      container.style.borderBottom = 'none';
      container.style.paddingTop = '0';
      container.style.paddingBottom = '0';
      container.style.marginTop = '1rem';
      container.style.marginBottom = '1rem';
      
      // Hide drop indicator
      const dropIndicator = document.getElementById('drop-indicator');
      if (dropIndicator) {
        dropIndicator.style.display = 'none';
      }
    };
    
    container.ondrop = (e) => {
      e.preventDefault();
      e.stopPropagation();
      container.style.borderTop = 'none';
      container.style.borderBottom = 'none';
      container.style.paddingTop = '0';
      container.style.paddingBottom = '0';
      container.style.marginTop = '1rem';
      container.style.marginBottom = '1rem';
      
      // Hide drop indicator
      const dropIndicator = document.getElementById('drop-indicator');
      if (dropIndicator) {
        dropIndicator.style.display = 'none';
      }
      
      // Clear scroll interval
      if (scrollInterval) {
        clearInterval(scrollInterval);
        scrollInterval = null;
      }
      
      // Handle file drops
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        // Don't handle file drops on individual videos, let the parent handle it
        return;
      }
      
      // Handle video reordering
      const dragType = e.dataTransfer?.getData('text/plain');
      if ((dragType === 'video-drag' || dragType === 'image-drag' || dragType === 'component-drag') && window.draggedElement && window.draggedElement !== container) {
        const draggedEl = window.draggedElement;
        const parent = container.parentNode;
        
        // Ensure we're not dropping inside another video container
        if (parent && draggedEl.parentNode && 
            !draggedEl.contains(container) && 
            !container.contains(draggedEl) &&
            (parent as HTMLElement).classList?.contains('blog-preview-content')) {
          const rect = container.getBoundingClientRect();
          const relativeY = e.clientY - rect.top;
          const dropZoneHeight = Math.min(rect.height * 0.5, 80); // 50% of height or 80px max
          
          // Store a reference to properly handle the operation
          const targetParent = parent;
          const targetContainer = container;
          const nextSibling = container.nextSibling;
          
          // Check if the dragged element is still a child of its parent
          if (draggedEl.parentNode && draggedEl.parentNode.contains(draggedEl)) {
            try {
              // Clone the element first as a backup
              const clonedEl = draggedEl.cloneNode(true) as HTMLElement;
              
              // Remove dragged element from its current position
              draggedEl.parentNode.removeChild(draggedEl);
              
              // Insert at new position - verify parent still contains the target
              if (targetParent && targetParent.contains(targetContainer)) {
                if (relativeY < dropZoneHeight) {
                  targetParent.insertBefore(draggedEl, targetContainer);
                } else {
                  // Check if nextSibling is still valid
                  if (nextSibling && targetParent.contains(nextSibling)) {
                    targetParent.insertBefore(draggedEl, nextSibling);
                  } else {
                    // Append at the end if nextSibling is no longer valid
                    targetParent.appendChild(draggedEl);
                  }
                }
                
                // Verify the element was successfully inserted
                if (!draggedEl.parentNode) {
                  console.error('Failed to insert element, restoring from clone');
                  targetParent.appendChild(clonedEl);
                }
                
                // Trigger HTML update directly
                updateHtmlFromPreview();
                
                // Re-setup drag handlers after DOM manipulation
                setTimeout(() => {
                  if (previewContentRef) {
                    const videos = previewContentRef.querySelectorAll('.blog_video');
                    videos.forEach((container) => {
                      const video = container.querySelector('video');
                      if (video) {
                        setupVideoDragHandlersForElement(container as HTMLElement, video as HTMLVideoElement);
                      }
                    });
                  }
                }, 10);
              } else {
                // If target is invalid, restore the element
                if (draggedEl.parentNode === null && parent) {
                  parent.appendChild(clonedEl);
                }
              }
            } catch (error) {
              console.error('Error during drag and drop:', error);
            }
          }
        }
        
        // Clear the dragged element reference immediately
        window.draggedElement = undefined;
      }
    };
  }, [previewContentRef]);

  // Helper function to set up drag handlers for any draggable component
  const setupComponentDragHandlers = useCallback((container: HTMLElement, dragHandle?: HTMLElement) => {
    const elementToDrag = dragHandle || container;
    let scrollInterval: any = null;
    
    elementToDrag.draggable = true;
    elementToDrag.style.cursor = 'move';
    elementToDrag.style.transition = 'transform 0.2s ease, box-shadow 0.2s ease';
    
    // Add smooth transition to container for visual feedback
    container.style.transition = 'all 0.3s ease';
    
    elementToDrag.ondragstart = (e) => {
      e.stopPropagation();
      window.draggedElement = container;
      e.dataTransfer!.effectAllowed = 'move';
      e.dataTransfer!.setData('text/plain', 'component-drag');
      container.style.opacity = '0.5';
      container.style.transform = 'scale(0.98)';
      elementToDrag.style.cursor = 'grabbing';
      
      // Add class for better visual feedback
      container.classList.add('dragging');
    };
    
    elementToDrag.ondragend = (e) => {
      e.stopPropagation();
      container.style.opacity = '1';
      container.style.transform = 'scale(1)';
      elementToDrag.style.cursor = 'move';
      container.classList.remove('dragging');
      window.draggedElement = undefined;
      
      // Clear scroll interval if active
      if (scrollInterval) {
        clearInterval(scrollInterval);
        scrollInterval = null;
      }
      
