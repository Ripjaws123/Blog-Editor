      font-family: 'Courier New', monospace;
    }
    
    pre {
      background: #f0f0f0;
      padding: 12px;
      border-radius: 4px;
      overflow-x: auto;
      
      code {
        background: none;
        padding: 0;
      }
    }
    
    img {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
    }
    
    a {
      color: #007cba;
      text-decoration: underline;
    }
    
    ul[data-type="taskList"] {
      list-style: none;
      padding: 0;
      
      li {
        display: flex;
        align-items: center;
        
        input[type="checkbox"] {
          margin-right: 8px;
        }
      }
    }
    
    table {
      border-collapse: collapse;
      table-layout: fixed;
      width: 100%;
      margin: 1em 0;
      
      td, th {
        min-width: 1em;
        border: 2px solid #ced4da;
        padding: 8px 12px;
        vertical-align: top;
        box-sizing: border-box;
        position: relative;
        
        > * {
          margin-bottom: 0;
        }
      }
      
      th {
        font-weight: bold;
        text-align: left;
        background-color: #f8f9fa;
      }
      
      .selectedCell:after {
        z-index: 2;
        position: absolute;
        content: "";
        left: 0; right: 0; top: 0; bottom: 0;
        background: rgba(200, 200, 255, 0.4);
        pointer-events: none;
      }
      
      .column-resize-handle {
        position: absolute;
        right: -2px;
        top: 0;
        bottom: -2px;
        width: 4px;
        background-color: #adf;
        pointer-events: none;
      }
    }
    
    hr {
      border: none;
      border-top: 2px solid #ddd;
      margin: 2em 0;
    }
    
    .ProseMirror-placeholder {
      color: #aaa;
      pointer-events: none;
      height: 0;
      
      &::before {
        content: attr(data-placeholder);
        float: left;
        pointer-events: none;
        height: 0;
      }
    }
    
    /* Dynamic styles from Vercel v0 will be injected globally and scoped to .ProseMirror */
  }
`;

